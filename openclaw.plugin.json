{
  "id": "s2-hanzi-ambient-renderer",
  "pluginId": "s2-hanzi-ambient-renderer",
  "version": "3.0.0",
  "type": "native-code",
  "entry": "handler.py",
  "runtime": "python3",
  "capabilities": {
    "dynamic_rendering": true,
    "spatial_color_mapping": true,
    "local_matrix_offline_mode": true,
    "local_network_push": true
  },
  "permissions": {
    "network": [
      "localhost", 
      "192.168.*.*"  
    ],
    "tools": [
      "process_spatial_telemetry"
    ]
  },
  "mcp_config": {
    "auto_discovery": true,
    "protocol_version": "2026.4.1"
  }
}